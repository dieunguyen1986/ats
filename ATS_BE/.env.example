# =============================================================================
# ATS Backend — Environment Variables Template
# =============================================================================
# Đây là file TEMPLATE an toàn để commit lên Git.
# Không chứa giá trị thực — chỉ là hướng dẫn cấu trúc.
#
# Hướng dẫn setup:
#   1. Copy file này: cp .env.example .env
#   2. Điền giá trị thực vào .env
#   3. File .env đã được .gitignore — KHÔNG BAO GIỜ commit .env lên Git
#
# Docker Compose sẽ tự động load file .env trong cùng thư mục.
# =============================================================================

# =============================================================================
# PostgreSQL Database
# =============================================================================
# Khi chạy Docker Compose: DB_HOST phải là tên service = "postgres"
# Khi chạy local (IDE):     DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ats_db
DB_USERNAME=ats_user
DB_PASSWORD=your_strong_password_here

# =============================================================================
# JWT Security
# =============================================================================
# Generate a strong secret (minimum 256-bit / 32 bytes):
#   Linux/Mac: openssl rand -hex 32
#   Result:    a8f3c2d1e5b7... (64 hex chars)
#
# KHÔNG dùng secret mặc định trong production!
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# =============================================================================
# Application Server
# =============================================================================
SERVER_PORT=8080

# =============================================================================
# Spring Profiles
# =============================================================================
# dev  → dùng khi chạy IDE local (verbose logs, Swagger enabled)
# prod → dùng khi deploy lên server (optimized, Swagger disabled)
SPRING_PROFILES_ACTIVE=prod
