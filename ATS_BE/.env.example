# ============================================================
# ATS Backend — Environment Variables Template
# ============================================================
# Đây là file TEMPLATE an toàn để commit lên Git.
# Copy file này thành .env rồi điền giá trị thực:
#   cp .env.example .env
# ============================================================

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ats_db
DB_USERNAME=
DB_PASSWORD=

# --- JWT Security ---
JWT_SECRET=
JWT_EXPIRATION_MS=86400000

# --- Application ---
SERVER_PORT=8080
